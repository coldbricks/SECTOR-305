{
  "name": "sector-305",
  "version": "0.1.0",
  "private": true,
  "description": "Certification-grade fictional Miami A-console PSAP trainer",
  "type": "module",
  "scripts": {
    "build": "npm run build -w @sector305/core && npm run build -w @sector305/web",
    "test": "npm run test -w @sector305/core",
    "test:all": "npm run test -w @sector305/core",
    "sim": "npm run sim -w @sector305/core",
    "dev": "npm run dev -w @sector305/web",
    "typecheck": "npm run typecheck -w @sector305/core && npm run typecheck -w @sector305/web",
    "validate:packs": "npm run validate:packs -w @sector305/core",
    "test:e2e": "npm run test:e2e -w @sector305/web",
    "radio:catalog": "node scripts/build-radio-catalog.mjs",
    "radio:catalog:full": "node scripts/build-radio-catalog.mjs --full",
    "radio:tts": "node scripts/build-radio-catalog.mjs && node scripts/elevenlabs-radio.mjs",
    "radio:tts:full": "node scripts/build-radio-catalog.mjs --full && node scripts/elevenlabs-radio.mjs",
    "radio:tts:dry": "node scripts/build-radio-catalog.mjs && node scripts/elevenlabs-radio.mjs --dry-run",
    "radio:tts:full:dry": "node scripts/build-radio-catalog.mjs --full && node scripts/elevenlabs-radio.mjs --dry-run",
    "radio:tts:force": "node scripts/build-radio-catalog.mjs && node scripts/elevenlabs-radio.mjs --force",
    "radio:sfx": "node scripts/elevenlabs-sfx.mjs",
    "radio:sfx:dry": "node scripts/elevenlabs-sfx.mjs --dry-run",
    "radio:sfx:force": "node scripts/elevenlabs-sfx.mjs --force",
    "radio:sfx:lab": "node scripts/elevenlabs-sfx-lab.mjs",
    "desktop:dev": "npm run start -w @sector305/desktop -- --dev",
    "desktop:pack": "npm run build && npm run pack -w @sector305/desktop",
    "desktop:dist": "npm run build && npm run dist -w @sector305/desktop",
    "desktop:installer": "npm run build && npm run dist:nsis -w @sector305/desktop",
    "scenario:list": "node scripts/scenario-305.mjs list",
    "scenario:validate": "node scripts/scenario-305.mjs validate",
    "scenario:pack": "node scripts/scenario-305.mjs pack",
    "scenario:unpack": "node scripts/scenario-305.mjs unpack"
  },
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
