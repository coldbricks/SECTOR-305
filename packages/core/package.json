    "test:watch": "vitest",
    "sim": "tsx src/cli/sim.ts",
    "validate:packs": "tsx src/cli/validate-packs.ts"
  },
  "dependencies": {
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
